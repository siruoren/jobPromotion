<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form" xmlns:c="/lib/credentials">
    <f:entry title="${%instanceName}" field="name">
        <f:textbox/>
    </f:entry>
    <f:entry title="${%sourceJenkinsUrl}" description="${%sourceJenkinsUrlDesc}" field="url">
        <f:textbox/>
    </f:entry>
    <f:entry title="${%credentialsId}" description="${%credentialsIdDesc}" field="credentialsId">
        <c:select/>
    </f:entry>
    <f:validateButton
        title="${%testConnection}"
        progress="${%testing}"
        method="testConnection"
        with="url,credentialsId"/>
    <f:entry title="">
        <div align="right">
            <f:repeatableDeleteButton/>
        </div>
    </f:entry>
</j:jelly>
